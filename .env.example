# ======================================================================
# Ponto Zero — variáveis de ambiente. Copie para `.env` e preencha.
# NUNCA comite o .env. Segredos só no servidor (Render -> Environment).
# ======================================================================

# --- Meta / Instagram Graph API ---------------------------------------
# App na Meta (developers.facebook.com) + App Review aprovado.
# A Basic Display API foi DESLIGADA (dez/2024) — usar Graph API.
META_APP_ID=
META_APP_SECRET=
# Deve bater EXATAMENTE com o redirect cadastrado no app da Meta:
META_REDIRECT_URI=https://app.mkt.cardozoesaggioro.com.br/auth/instagram/callback
IG_SCOPES=instagram_basic,pages_show_list,pages_read_engagement,business_management

# --- LLM (proxy no servidor) ------------------------------------------
LLM_API_KEY=
# Anthropic (claude-*) ou OpenAI (gpt-*/o*). O provedor é inferido pelo nome do
# modelo; use LLM_PROVIDER só para forçar (anthropic|openai).
LLM_MODEL=claude-sonnet-4-5
LLM_PROVIDER=

# --- Servidor ----------------------------------------------------------
# O Render injeta PORT automaticamente; localmente, 8000 é o padrão.
PORT=8000
